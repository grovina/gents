#!/usr/bin/env python3
"""gent-schedule — the box's one scheduler: durable reminders + cron triggers.

Two kinds of timed wake-up, one daemon, fired into the box's unified event stream
(see gent-events) so they surface through the one Monitor the agent watches:

  REMINDERS — "do X later / eventually" (interval or one-shot, AT-LEAST-ONCE).
    gent-schedule add --note "<text>" [--in <dur> | --at <iso>] [--every <dur>]
    gent-schedule list | due | done <id> | rm <id>
  Stored append-only in $GENT_STATE_DIR/schedule.jsonl (add/fire/done, fold-on-read).
  A fired reminder stays in `due` until you `done` it, so one missed while the
  (flaky) Monitor was down is caught at the next reconcile. A recurring (`--every`)
  reminder has exactly ONE live instance: it fires once and nags in `due` until
  you handle it, then `done` schedules the next occurrence from NOW (done time)
  and `rm` ends the series. So `done` ALWAYS advances the cadence and `rm` ALWAYS
  stops it — neither depends on whether the daemon fired the instance first. A
  note is a nudge — you pick the moment (for a strict wall-clock cadence that
  fires whether or not you ack it, use a CRON TRIGGER instead).

  CRON TRIGGERS — "fire at this wall-clock slot" (calendar, NO backfill).
  A hand-edited JSON array at $GENT_CRON_PATH (default $GENT_STATE_DIR/cron.json):
    [{"name":"morning_digest","cron":"32 8 * * *","enabled":true,
      "event":{"topic":"morning_digest","note":"…"}},              # nudge the agent
     {"name":"nightly_backup","cron":"0 3 * * *","run":"./backup.sh"},   # RUN a command
     {"name":"health","cron":"*/15 * * * *","run":["python3","hc.py"],"notify":"always"}]
  5-field cron (min hour dom month dow, dow 0=Sun) in $GENT_SCHEDULE_TZ — which
  defaults to the box's $TZ, then UTC (set TZ once; the scheduler follows it, and
  ZoneInfo makes the slot DST-correct). On a matching minute an entry does one or
  both of:
    • `event`: emit the payload verbatim into the stream (kind defaults to
      "scheduled", `name` added) — a pure nudge the agent reads and acts on.
    • `run`:   EXECUTE a command in the repo dir. A string runs via the shell
      (`./backup.sh && ...`); a list runs argv-style (no shell). The command is
      launched DETACHED so a slow job never stalls the minute-aligned daemon, and
      its outcome comes back as a `scheduled_run` event (exit code, duration, an
      output tail, and the path to a full log under $GENT_STATE_DIR/run-logs/).
      `notify` controls that event: "onfail" (default — surface only a non-zero
      exit), "always", or "never". A run over $GENT_RUN_TIMEOUT_SECS (default 3600)
      is killed and reported as exit 124. This is the "no ack, just run it" path;
      for a reminder you personally handle, use a note above.
  No backfill — a daemon that was down doesn't replay missed slots; de-dup is per
  (name, minute). Edit the file freely; it's re-read every tick.

The daemon (`gent-schedule fire-due`, run minute-aligned by the bootstrap) fires
both. Events land in $GENT_EVENTS_PATH (default $GENT_STATE_DIR/events.jsonl).
"""
import sys
import os
import re
import json
import uuid
import datetime
import subprocess

try:
    from zoneinfo import ZoneInfo
except Exception:  # pragma: no cover
    ZoneInfo = None


def state_dir():
    return os.environ.get("GENT_STATE_DIR") or os.path.join(
        os.path.expanduser("~"), ".local", "state", "gent")


def _path(env, name):
    d = state_dir()
    os.makedirs(d, exist_ok=True)
    return os.environ.get(env) or os.path.join(d, name)


def sched_path():
    return _path("GENT_SCHEDULE_PATH", "schedule.jsonl")


def cron_path():
    return _path("GENT_CRON_PATH", "cron.json")


def events_path():
    return _path("GENT_EVENTS_PATH", "events.jsonl")


def cron_state_path():
    return _path("GENT_CRON_STATE_PATH", "cron-fired.json")


def now():
    return datetime.datetime.now(datetime.UTC)


def iso(dt):
    return dt.isoformat()


def emit_event(obj):
    """Append one event (ts added) to the unified event stream."""
    obj = dict(obj)
    obj.setdefault("ts", iso(now()))
    with open(events_path(), "a", encoding="utf-8") as f:
        f.write(json.dumps(obj, ensure_ascii=False) + "\n")


# ── reminders (append-only schedule.jsonl) ────────────────────────────────────

def parse_dur(s):
    total, matched = 0, False
    for n, u in re.findall(r"(\d+)\s*([dhms])", s or ""):
        matched = True
        total += int(n) * {"d": 86400, "h": 3600, "m": 60, "s": 1}[u]
    if not matched:
        sys.exit("bad duration %r (use e.g. 2d, 90m, 1d6h)" % s)
    return total


def append_sched(rec):
    with open(sched_path(), "a", encoding="utf-8") as f:
        f.write(json.dumps(rec, ensure_ascii=False) + "\n")


def fold():
    items = {}
    p = sched_path()
    if not os.path.exists(p):
        return items
    with open(p, encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                r = json.loads(line)
            except Exception:
                continue
            op, rid = r.get("op"), r.get("id")
            if not rid:
                continue
            if op == "add":
                items[rid] = {"add": r, "fired": False, "done": False}
            elif op == "fire" and rid in items:
                items[rid]["fired"] = True
            elif op == "done" and rid in items:
                items[rid]["done"] = True
    return items


def pending(items):
    return {rid: it for rid, it in items.items() if not it["done"]}


def fire_at_of(it):
    return datetime.datetime.fromisoformat(it["add"]["fire_at"])


def humanize(dt):
    secs = (dt - now()).total_seconds()
    past = secs < 0
    secs = abs(secs)
    d, h, m = int(secs // 86400), int(secs % 86400 // 3600), int(secs % 3600 // 60)
    parts = []
    if d:
        parts.append("%dd" % d)
    if h:
        parts.append("%dh" % h)
    if m and not d:
        parts.append("%dm" % m)
    s = " ".join(parts) or "<1m"
    return "%s ago" % s if past else "in %s" % s


def cmd_add(argv):
    note = in_d = at = every = None
    i = 0
    while i < len(argv):
        a = argv[i]
        if a == "--note":
            note = argv[i + 1]; i += 2
        elif a == "--in":
            in_d = argv[i + 1]; i += 2
        elif a == "--at":
            at = argv[i + 1]; i += 2
        elif a == "--every":
            every = argv[i + 1]; i += 2
        else:
            sys.exit("add: unknown arg %r" % a)
    if not note:
        sys.exit("add: --note required")
    recur = parse_dur(every) if every else None
    if at:
        try:
            fire = datetime.datetime.fromisoformat(at.replace("Z", "+00:00"))
        except Exception:
            sys.exit("add: bad --at %r (use ISO 8601, e.g. 2026-06-15T09:00:00Z)" % at)
        if fire.tzinfo is None:
            fire = fire.replace(tzinfo=datetime.UTC)
    elif in_d:
        fire = now() + datetime.timedelta(seconds=parse_dur(in_d))
    elif recur:
        fire = now() + datetime.timedelta(seconds=recur)
    else:
        sys.exit("add: need --in, --at, or --every (for a calendar slot, add a cron entry to %s)" % cron_path())
    rid = uuid.uuid4().hex[:8]
    rec = {"op": "add", "id": rid, "fire_at": iso(fire), "note": note, "created_at": iso(now())}
    if recur:
        rec["recur_ms"] = recur * 1000
    append_sched(rec)
    print("scheduled %s for %s%s" % (rid, iso(fire), " (every %s)" % every if every else ""))


def cmd_list(_argv):
    items = pending(fold())
    if not items:
        print("no pending reminders")
        return
    rows = sorted(items.values(), key=fire_at_of)
    print("%d pending reminder(s):" % len(rows))
    for it in rows:
        a = it["add"]
        recur = " (every %ds)" % (a["recur_ms"] // 1000) if a.get("recur_ms") else ""
        flag = " ⏰fired" if it["fired"] else ""
        print("  %s  %-16s %s%s%s" % (a["id"], humanize(fire_at_of(it)), a["note"], recur, flag))


def cmd_due(_argv):
    items = pending(fold())
    n = now()
    rows = sorted([it for it in items.values() if fire_at_of(it) <= n], key=fire_at_of)
    if not rows:
        print("no due reminders — nothing missed")
        return
    for it in rows:
        a = it["add"]
        print("  %s  %s  (run `gent-schedule done %s` once handled)" % (a["id"], a["note"], a["id"]))


def _resolve(rid, reschedule):
    """Mark reminder `rid` done. If it recurs and `reschedule`, spawn the next
    occurrence (from now) so `done` deterministically advances the cadence;
    `rm` passes reschedule=False to end the series."""
    items = fold()
    if rid not in items:
        sys.exit("no reminder %s" % rid)
    if items[rid]["done"]:
        print("%s already done" % rid)
        return
    n = now()
    append_sched({"op": "done", "id": rid, "at": iso(n)})
    recur = items[rid]["add"].get("recur_ms")
    if reschedule and recur:
        nid = uuid.uuid4().hex[:8]
        nxt = n + datetime.timedelta(seconds=recur // 1000)
        append_sched({"op": "add", "id": nid, "fire_at": iso(nxt),
                      "note": items[rid]["add"]["note"], "created_at": iso(n),
                      "recur_ms": recur})
        print("done %s — next occurrence %s at %s" % (rid, nid, iso(nxt)))
    else:
        print(("done %s" if reschedule else "removed %s") % rid)


def cmd_done(argv):
    if not argv:
        sys.exit("usage: gent-schedule done <id>")
    _resolve(argv[0], reschedule=True)


def cmd_rm(argv):
    if not argv:
        sys.exit("usage: gent-schedule rm <id>")
    _resolve(argv[0], reschedule=False)


# ── cron triggers (calendar slots; no backfill) ───────────────────────────────

def _expand_cron_field(field, lo, hi):
    values = set()
    for part in field.split(","):
        step = 1
        token = part
        if "/" in token:
            token, step_s = token.split("/", 1)
            step = int(step_s)
        if token == "*":
            start, end = lo, hi
        elif "-" in token:
            start_s, end_s = token.split("-", 1)
            start, end = int(start_s), int(end_s)
        else:
            start = end = int(token)
        values.update(range(start, end + 1, step))
    return {v for v in values if lo <= v <= hi}


def _cron_matches(expr, dt):
    """True if 5-field cron `expr` (min hour dom month dow) matches local dt.
    dow uses cron convention 0=Sunday..6=Saturday; dom/dow are ANDed."""
    minute, hour, dom, month, dow = expr.split()
    cron_dow = (dt.weekday() + 1) % 7
    return (
        dt.minute in _expand_cron_field(minute, 0, 59)
        and dt.hour in _expand_cron_field(hour, 0, 23)
        and dt.day in _expand_cron_field(dom, 1, 31)
        and dt.month in _expand_cron_field(month, 1, 12)
        and cron_dow in _expand_cron_field(dow, 0, 6)
    )


def _warn_bad_tz(name):
    """Surface an unknown-TZ name ONCE (not every minute — the daemon reinvokes
    fresh each tick, so dedup on disk keyed by the bad name). Beats silently
    firing every cron slot in UTC, hours off from what was intended."""
    marker = os.path.join(state_dir(), "tz-warned")
    try:
        prev = open(marker, encoding="utf-8").read().strip() if os.path.exists(marker) else ""
    except OSError:
        prev = ""
    if prev == name:
        return
    emit_event({"kind": "schedule_error",
                "msg": "gent-schedule: unknown TZ %r (GENT_SCHEDULE_TZ/TZ) → firing cron in UTC" % name})
    try:
        with open(marker, "w", encoding="utf-8") as f:
            f.write(name)
    except OSError:
        pass


def _local_tz():
    """Zone for cron wall-clock slots. Prefer GENT_SCHEDULE_TZ, else fall back to
    the box's OS TZ, else UTC — so setting TZ once makes the OS and the scheduler
    agree, and GENT_SCHEDULE_TZ stays an explicit override for the rare case where
    they should differ. Absolute reminders (--at/--in/--every) don't touch this;
    they're stored/compared in UTC and are TZ-agnostic by construction."""
    name = os.environ.get("GENT_SCHEDULE_TZ") or os.environ.get("TZ") or "UTC"
    if ZoneInfo is not None:
        try:
            return ZoneInfo(name)
        except Exception:
            _warn_bad_tz(name)
    return datetime.UTC


def _fire_cron():
    p = cron_path()
    if not os.path.exists(p):
        return
    try:
        entries = json.loads(open(p, encoding="utf-8").read())
    except Exception as e:
        emit_event({"kind": "schedule_error", "msg": "gent-schedule: bad cron file: %r" % e})
        return
    if not isinstance(entries, list):
        return
    dt = datetime.datetime.now(_local_tz())
    minute_key = dt.strftime("%Y-%m-%dT%H:%M")
    sp = cron_state_path()
    fired = {}
    if os.path.exists(sp):
        try:
            fired = json.loads(open(sp, encoding="utf-8").read())
        except Exception:
            fired = {}
    changed = False
    for ent in entries:
        if not isinstance(ent, dict) or not ent.get("enabled", True):
            continue
        name = ent.get("name", "unnamed")
        cron = ent.get("cron")
        if not cron:
            continue
        try:
            hit = _cron_matches(cron, dt)
        except Exception as e:
            emit_event({"kind": "schedule_error", "msg": "gent-schedule: bad cron %r: %r" % (name, e)})
            continue
        if hit and fired.get(name) != minute_key:
            fired[name] = minute_key
            changed = True
            # A `run` command executes; an `event` payload nudges the agent. An
            # entry may have either or both (run, then nudge).
            run = ent.get("run")
            if run is not None:
                _launch_run(name, run, ent.get("notify", "onfail"))
            if ent.get("event") is not None:
                event = dict(ent["event"])
                event.setdefault("kind", "scheduled")
                event["name"] = name
                emit_event(event)
            if run is None and ent.get("event") is None:
                emit_event({"kind": "schedule_error",
                            "msg": "gent-schedule: cron %r has neither `run` nor `event`" % name})
    if changed:
        with open(sp, "w", encoding="utf-8") as f:
            json.dump(fired, f)


def _launch_run(name, run, notify):
    """Launch a cron `run` command DETACHED (its own session) so a slow job never
    stalls the minute-aligned daemon. The child (`_exec`) runs the command, logs
    its full output, and emits a `scheduled_run` event with the outcome."""
    try:
        subprocess.Popen(
            [sys.executable, os.path.abspath(__file__), "_exec",
             name, json.dumps(run), notify or "onfail"],
            stdin=subprocess.DEVNULL, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            start_new_session=True)
    except Exception as e:
        emit_event({"kind": "schedule_error",
                    "msg": "gent-schedule: could not launch run %r: %r" % (name, e)})


def cmd_exec(argv):
    """Internal (spawned by the cron path): run a scheduled command, log its full
    output, and emit a `scheduled_run` result event. Detached from the daemon, so
    it's free to take as long as it needs (up to $GENT_RUN_TIMEOUT_SECS)."""
    if len(argv) < 2:
        sys.exit("usage: gent-schedule _exec <name> <run-json> [notify]")
    name = argv[0]
    try:
        run = json.loads(argv[1])           # str → shell; list → argv (no shell)
    except Exception:
        run = argv[1]
    notify = argv[2] if len(argv) > 2 else "onfail"
    try:
        timeout = int(os.environ.get("GENT_RUN_TIMEOUT_SECS", "3600"))
    except ValueError:
        timeout = 3600
    start = now()
    shell = isinstance(run, str)
    killed = False
    try:
        p = subprocess.run(run, shell=shell, capture_output=True, text=True, timeout=timeout)
        rc, out, err = p.returncode, p.stdout or "", p.stderr or ""
    except subprocess.TimeoutExpired as e:
        rc, killed = 124, True
        out = (e.stdout.decode("utf-8", "replace") if isinstance(e.stdout, bytes) else (e.stdout or ""))
        err = (e.stderr.decode("utf-8", "replace") if isinstance(e.stderr, bytes) else (e.stderr or ""))
    except Exception as e:
        rc, out, err = 127, "", "gent-schedule: exec failed: %r" % e
    dur = (now() - start).total_seconds()
    combined = (out + ("\n" if out and err else "") + err).strip()

    logpath = ""
    try:
        logdir = os.path.join(state_dir(), "run-logs")
        os.makedirs(logdir, exist_ok=True)
        safe = re.sub(r"[^A-Za-z0-9_.-]+", "_", name) or "run"
        logpath = os.path.join(logdir, "%s-%s.log" % (safe, start.strftime("%Y%m%dT%H%M%S")))
        with open(logpath, "w", encoding="utf-8") as f:
            f.write("# %s\n# run: %s\n# %s  exit %s%s  %.1fs\n\n%s\n" % (
                name, run, iso(start), rc, " TIMEOUT" if killed else "", dur, combined))
    except OSError:
        logpath = ""

    tail = "\n".join(combined.splitlines()[-6:])
    if len(tail) > 600:
        tail = "…" + tail[-600:]
    ok = (rc == 0)
    visible = (notify == "always") or (notify != "never" and not ok)
    ev = {"kind": "scheduled_run" if visible else "self_scheduled_run",
          "name": name, "exit": rc, "ok": ok, "secs": round(dur, 1)}
    if killed:
        ev["timeout"] = True
    if tail:
        ev["tail"] = tail
    if logpath:
        ev["log"] = logpath
    emit_event(ev)


def cmd_fire_due(_argv):
    """Daemon tick: fire due reminders (at-least-once) + matching cron triggers
    (calendar, no-backfill). Run minute-aligned by the bootstrap."""
    # Reminders.
    items = fold()
    n = now()
    for rid, it in items.items():
        if it["done"] or it["fired"]:
            continue
        if fire_at_of(it) > n:
            continue
        a = it["add"]
        append_sched({"op": "fire", "id": rid, "at": iso(n)})
        emit_event({"kind": "reminder", "id": rid, "note": a["note"]})
        # A recurring reminder does NOT self-advance on fire; it nags in `due`
        # until acknowledged, and `done` schedules the next occurrence. This
        # keeps recurrence deterministic (only `done` advances, only `rm` ends).
    # Cron triggers.
    _fire_cron()


def main():
    if len(sys.argv) < 2:
        sys.exit("usage: gent-schedule <add|list|due|done|rm|fire-due> ...")
    cmd, rest = sys.argv[1], sys.argv[2:]
    return {
        "add": cmd_add, "list": cmd_list, "due": cmd_due,
        "done": cmd_done, "rm": cmd_rm, "fire-due": cmd_fire_due,
        "_exec": cmd_exec,
    }.get(cmd, lambda _a: sys.exit("gent-schedule: unknown subcommand %r" % cmd))(rest)


if __name__ == "__main__":
    main()
