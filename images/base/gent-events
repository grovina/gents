#!/usr/bin/env python3
"""gent-events — the box's unified event bus.

ONE append-only stream ($GENT_STATE_DIR/events.jsonl, default ~/.local/state/gent)
carries EVERY async wake-up — inbound telegram, due reminders, and whatever else a
box wires in — and the agent arms ONE Monitor on `gent-events watch`. Box-supervised
sources (the schedule daemon, the telegram bridge) feed it with `gent-events emit`.
This is the gents analogue of pickle's events.jsonl: one inbox, one Monitor, many
sources. The durable per-source logs (telegram history.jsonl, schedule.jsonl) remain
the reconcile backstop — events.jsonl is the realtime surface, lossy by design if the
Monitor is down (a gap is recovered by `tg pending` / `gent-schedule due` on re-arm).

  gent-events emit <kind> [key=value ...]   append an event (ts added automatically)
  gent-events watch                         tail + format the stream (the Monitor command)

`watch` is a NEWEST-WINS SINGLETON (pidfile, like the tg poller): arming a second
one stands the older one down. Duplicate watchers are otherwise invisible — the
watchdog's liveness check is a `pgrep -f "gent-events watch"`, which any number of
them satisfy — and each extra tail delivers every event again, so an agent that
ACTS on events acts twice (replies twice, sends the same poll twice). Newest-wins
because the newest watcher is the one the harness actually holds the Monitor on.
"""
import sys
import os
import json
import time
import signal
import datetime
import threading
import subprocess


def state_dir():
    return os.environ.get("GENT_STATE_DIR") or os.path.join(
        os.path.expanduser("~"), ".local", "state", "gent")


def events_path():
    d = state_dir()
    os.makedirs(d, exist_ok=True)
    return os.environ.get("GENT_EVENTS_PATH") or os.path.join(d, "events.jsonl")


def watch_pid_path():
    d = state_dir()
    os.makedirs(d, exist_ok=True)
    return os.path.join(d, "watch.pid")


def cmd_emit(argv):
    if not argv:
        sys.exit("usage: gent-events emit <kind> [key=value ...]")
    ev = {"kind": argv[0], "ts": datetime.datetime.now(datetime.UTC).isoformat()}
    for kv in argv[1:]:
        if "=" not in kv:
            sys.exit("emit: args after <kind> must be key=value (got %r)" % kv)
        k, v = kv.split("=", 1)
        ev[k] = v
    # A single write of a small line is atomic on POSIX — concurrent sources are safe.
    with open(events_path(), "a", encoding="utf-8") as f:
        f.write(json.dumps(ev, ensure_ascii=False) + "\n")


def _fmt(ev):
    k = ev.get("kind")
    if k == "reminder":
        rid = ev.get("id", "?")
        return "⏰ Reminder [%s]: %s  (run `gent-schedule done %s` once handled)" % (
            rid, ev.get("note", ""), rid)
    if k == "telegram":
        return ev.get("line") or ev.get("text") or json.dumps(ev, ensure_ascii=False)
    if k == "schedule_error":
        return "⚠️ schedule: %s" % ev.get("msg", "")
    if k == "scheduled_run":
        name, secs = ev.get("name", "?"), ev.get("secs")
        if ev.get("ok"):
            return "✅ scheduled run %s ok (%ss)" % (name, secs)
        to = " TIMEOUT" if ev.get("timeout") else ""
        head = "❌ scheduled run %s failed%s (exit %s, %ss)" % (name, to, ev.get("exit"), secs)
        if ev.get("tail"):
            head += ":\n%s" % ev["tail"]
        if ev.get("log"):
            head += "\n  full log: %s" % ev["log"]
        return head
    extra = " ".join("%s=%s" % (kk, vv) for kk, vv in ev.items() if kk not in ("kind", "ts"))
    return "• %s %s" % (k, extra)


def _claim_watch(child):
    """Become THE watcher: take the pidfile, then stand down the moment someone
    newer takes it. Without this, a watchdog poke that lands while the Monitor is
    actually alive leaves two tails on the stream and the agent sees — and acts on
    — every event twice; nothing downstream can tell the copies apart. The guard
    polls rather than waiting on a signal so an IDLE watcher (blocked on readline,
    no events flowing) still stands down promptly."""
    path = watch_pid_path()
    mypid = os.getpid()

    def owner():
        try:
            with open(path, encoding="utf-8") as f:
                return f.read().strip()
        except OSError:
            return ""

    with open(path, "w", encoding="utf-8") as f:
        f.write(str(mypid))

    def guard():
        while True:
            time.sleep(2)
            if owner() != str(mypid):
                print("[gent-events] superseded by a newer watch (pid %s) — standing down"
                      % (owner() or "?"), flush=True)
                child.terminate()
                os._exit(0)

    threading.Thread(target=guard, daemon=True).start()


def _release_watch():
    """Drop the pidfile if it's still ours (a newer watcher's claim is left alone)."""
    path = watch_pid_path()
    try:
        with open(path, encoding="utf-8") as f:
            if f.read().strip() != str(os.getpid()):
                return
        os.remove(path)
    except OSError:
        pass


def cmd_watch(_argv):
    path = events_path()
    open(path, "a").close()  # ensure it exists so `tail -F` has a target immediately
    # SIGTERM (how the harness retires a Monitor) must unwind, not abort — else we
    # leave a pidfile pointing at a dead process for the next debugger to puzzle over.
    signal.signal(signal.SIGTERM, lambda *_: sys.exit(0))
    p = subprocess.Popen(["tail", "-n", "0", "-F", path], stdout=subprocess.PIPE, text=True)
    _claim_watch(p)          # newest-wins: any older watcher stands down now
    try:
        for line in p.stdout:
            line = line.strip()
            if not line:
                continue
            try:
                ev = json.loads(line)
            except Exception:
                continue
            if str(ev.get("kind", "")).startswith("self_"):
                continue  # outbound / self events don't echo back into the session
            print(_fmt(ev), flush=True)
    except KeyboardInterrupt:
        pass
    finally:
        p.terminate()
        _release_watch()


def main():
    if len(sys.argv) < 2:
        sys.exit("usage: gent-events <emit|watch> ...")
    cmd, rest = sys.argv[1], sys.argv[2:]
    if cmd == "emit":
        return cmd_emit(rest)
    if cmd == "watch":
        return cmd_watch(rest)
    sys.exit("gent-events: unknown subcommand %r (want emit|watch)" % cmd)


if __name__ == "__main__":
    main()
