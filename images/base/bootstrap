#!/usr/bin/env bash
# gents container entrypoint: start a persistent claude YOLO session in tmux
# and keep the container alive. Attach from the host with `gents attach <repo>`.
set -euo pipefail

# The repo is mounted at its real HOST absolute path (gent passes it as
# GENT_REPO_DIR) so the box is a path-faithful subset of your machine and shares
# one per-repo claude namespace with host sessions. Fallback to the legacy /repo
# for any box started by an older gent that didn't set it.
REPO="${GENT_REPO_DIR:-/repo}"
cd "$REPO"

# Boxes normally authenticate via the SHARED ~/.claude login (a bind-mount —
# see below), so only warn when there's no shared login yet AND no env token —
# otherwise this cried wolf on every correctly-configured box.
if [ ! -f "$HOME/.claude/.credentials.json" ] \
   && [ -z "${CLAUDE_CODE_OAUTH_TOKEN:-}" ] && [ -z "${ANTHROPIC_API_KEY:-}" ]; then
  echo "gents: WARNING — no shared login yet, and no CLAUDE_CODE_OAUTH_TOKEN /" >&2
  echo "       ANTHROPIC_API_KEY; claude will be unauthenticated. Run /login once" >&2
  echo "       in any box (see gents README, auth section)." >&2
fi

# Seed claude config so the box never blocks on interactive first-run
# onboarding (theme picker etc). /home/gent is a persistent volume, so this
# only fires on a fresh box.
mkdir -p "$HOME/.claude"
# Skip first-run onboarding AND pre-trust THIS repo's mount path. MERGE (not
# create-if-absent): the home volume persists ~/.claude.json across restarts, and
# an older box's copy pre-trusts only the legacy /repo path — without merging the
# real repo path in, claude would sit blocked on the trust dialog now that we
# mount at the actual absolute path. Idempotent; everything else is preserved.
# resumeReturnDismissed: the supervisor relaunches with `--resume`, and a resumed
# session that's grown large enough triggers an interactive "Resume from summary
# vs. as-is" picker that BLOCKS the TUI waiting on a keypress — fatal for an
# unattended box. This is the exact flag claude's own "Don't ask me again" option
# persists (it gates the picker: shown only when this is falsy); pre-setting it
# makes every box resume as-is silently. We manage length via periodic /clear
# anyway, so summary-on-resume is unwanted regardless.
CJSON="$HOME/.claude.json"
# Reset to {} if missing, EMPTY, or unparseable — not just absent. A disk-full
# write can leave a 0-byte file; `-f` passes it through, and then `jq` on empty
# input exits 0 with empty output, so the merge below would mv empty-over-empty
# and claude crash-loops on "invalid JSON" forever. Validate before merging.
{ [ -s "$CJSON" ] && jq -e . "$CJSON" >/dev/null 2>&1; } || echo '{}' > "$CJSON"
if _tmp="$(mktemp)" && jq --arg r "$REPO" '
      .hasCompletedOnboarding = true
    | (.theme //= "dark") | (.numStartups //= 5)
    | .resumeReturnDismissed = true
    | .projects[$r].hasTrustDialogAccepted = true
  ' "$CJSON" > "$_tmp" 2>/dev/null; then
  mv "$_tmp" "$CJSON"
else
  rm -f "${_tmp:-}"
  cat > "$CJSON" <<JSON
{ "hasCompletedOnboarding": true, "theme": "dark", "numStartups": 5,
  "resumeReturnDismissed": true,
  "projects": { "$REPO": { "hasTrustDialogAccepted": true } } }
JSON
fi
# settings.json: ENFORCE the gents baseline on every start by MERGING (so keys
# claude writes at runtime — e.g. agentPushNotifEnabled — survive, but our
# values always win). Skip the bypass-mode warning, enable Remote Control at
# startup, drop the co-authored-by commit trailer.
SETTINGS="$HOME/.claude/settings.json"
# Same guard as .claude.json: reset on empty/unparseable, not just absent — else
# the jq merge below mv's empty-over-empty and the baseline never applies.
{ [ -s "$SETTINGS" ] && jq -e . "$SETTINGS" >/dev/null 2>&1; } || echo '{}' > "$SETTINGS"
_baseline='{skipDangerousModePermissionPrompt: true, remoteControlAtStartup: true, includeCoAuthoredBy: false}'
if _tmp="$(mktemp)" && jq ". + $_baseline" "$SETTINGS" > "$_tmp" 2>/dev/null; then
  mv "$_tmp" "$SETTINGS"
else
  rm -f "${_tmp:-}"
  printf '{"skipDangerousModePermissionPrompt": true, "remoteControlAtStartup": true, "includeCoAuthoredBy": false}\n' > "$SETTINGS"
fi

# Fleet-granted credentials are AUTHORITATIVE. A repo carries its own
# .claude/settings.json / settings.local.json (mounted in via the repo), and a host
# checkout's `env` block there pins GOOGLE_APPLICATION_CREDENTIALS at a *host*
# path (e.g. /Users/you/.config/gcloud/key.json) that doesn't exist in the box.
# That project-local `env` OUTRANKS the container's own `-e`, so it would
# silently point the in-box claude at a missing key — masking the SA the fleet
# actually granted (this is exactly what stranded the platform box's deploys).
# Re-assert the fleet value at the MANAGED settings tier (the highest — no
# project file can override it) so the grant always wins. Only the credential
# PATH is pinned; every other setting still merges normally. Repo-agnostic: any
# box whose fleet entry sets GOOGLE_APPLICATION_CREDENTIALS is protected.
if [ -n "${GOOGLE_APPLICATION_CREDENTIALS:-}" ]; then
  sudo install -d -m 755 /etc/claude-code
  printf '{"env":{"GOOGLE_APPLICATION_CREDENTIALS":"%s"}}\n' "$GOOGLE_APPLICATION_CREDENTIALS" \
    | sudo tee /etc/claude-code/managed-settings.json >/dev/null
fi

# Auth: ~/.claude is a SHARED bind-mount across all boxes (gents mounts it), so
# the login lives there — populated once by `/login` in any box, refreshes
# propagate to all. Nothing to copy here.

# Git push/pull: a per-repo GitHub deploy key (write-scoped to THIS repo only)
# is mounted read-only at /secrets/ssh/key — gents mints + registers it and
# wires the mount from the catalog. Install it as the DEFAULT ssh identity with
# correct perms so `git push` just works (the host key is already trusted
# fleet-wide via /etc/ssh/ssh_known_hosts). Inside the box it's simply "the
# key"; the catalog holds one per repo. Idempotent — refreshed each start.
if [ -f /secrets/ssh/key ]; then
  install -d -m 700 "$HOME/.ssh"
  install -m 600 /secrets/ssh/key "$HOME/.ssh/id_ed25519"
fi

# Fleet-shared pnpm store (gents mounts it at /pnpm-store). Take ownership of the
# mount ROOT so pnpm — running as gent — can populate it; non-recursive, since the
# package files pnpm writes underneath are already gent's. Cheap + idempotent.
if [ -d /pnpm-store ]; then sudo chown gent:gent /pnpm-store 2>/dev/null || true; fi

# Derived build outputs declared in gent.json:derived ({path: build-command}).
# gents mounts a per-box volume at each <repo>/<path>, MASKING the host's copy; here
# we take ownership (a fresh volume mounts root-owned) and run each build so the box
# has its OWN platform-native artifacts before claude + services come up. The build
# is best-effort: a failure (e.g. transient network) must never wedge the box — it
# logs and retries next start. All tool-specific detail lives in the command itself.
if [ -f "$REPO/gent.json" ] && command -v jq >/dev/null 2>&1; then
  jq -r '(.derived // {}) | to_entries[] | "\(.key)\t\(.value)"' "$REPO/gent.json" \
  | while IFS=$'\t' read -r dpath dcmd; do
      [ -n "$dpath" ] || continue
      sudo chown gent:gent "$REPO/$dpath" 2>/dev/null || true
      echo "gents: building derived '$dpath' → $dcmd" >&2
      ( cd "$REPO" && eval "$dcmd" ) || echo "gents: derived build '$dpath' failed (continuing)" >&2
    done
fi

# Optional per-repo first-run hook — the repo's own business (install deps,
# start its poller, etc). Best-effort, never blocks the session coming up.
if [ -f "$REPO/.gent/setup.sh" ]; then
  echo "gents: running repo hook .gent/setup.sh" >&2
  bash "$REPO/.gent/setup.sh" || echo "gents: .gent/setup.sh failed (continuing)" >&2
fi

# Persistent, attachable, SELF-HEALING session. If claude exits — crash, OOM,
# or a transient auth gap on a box that booted before `/login` populated the
# shared ~/.claude — relaunch it (same loop the sidecar services use below),
# so a box never silently rots at a dead shell. For a debugging shell that
# does NOT auto-restart, use `gent shell <repo>` (a separate window/exec).
# To stop the loop: `gent down <repo>` (or kill the 'claude' window).
# tmux config lives in the image at /etc/tmux.conf (truecolor + invisible UI so
# attaching feels like a local claude) — no per-start heredoc needed here.
# Older bootstraps wrote ~/.tmux.conf, which persists in the home volume and
# SHADOWS /etc/tmux.conf (it loads second), re-pinning default-terminal
# screen-256color and silently undoing the truecolor fix on every pre-existing
# box. Remove it so /etc/tmux.conf is genuinely the single source of truth.
rm -f "$HOME/.tmux.conf"

# Name the session after the repo (hostname is gent-<repo>) so it's identifiable
# in the phone app / claude.ai/code when several boxes run under one login.
REPO_NAME="$(hostname)"; REPO_NAME="${REPO_NAME#gent-}"
# Per-box session continuity that FOLLOWS a /clear. The box keeps a persistent
# session across restarts (crash, OOM, `gent down`/`up`) so the phone reconnects
# the SAME Remote Control session instead of accumulating offline ghosts — but a
# /clear must stick. `/clear` doesn't wipe the live transcript: it FREEZES it and
# starts a brand-new <id>.jsonl, so claude silently migrates to a new session id
# (the launch cmdline still names the old one). A supervisor pinned to one id
# therefore RESURRECTS the pre-clear conversation on the next relaunch — the bug
# this replaces. So we resume the NEWEST transcript in the project dir, which is
# the same session across plain restarts AND the post-clear session after a
# gent-clear. Only when NO transcript exists yet (true first boot) do we mint a
# deterministic, box-OWNED id — never grafting a host session that merely happens
# to be newest (boxed repos aren't driven from the host, so "newest" is the box's
# own; the deterministic id is just the first-boot seed + a stable phone name).
PINNED_ID="$(python3 -c "import uuid,sys;print(uuid.uuid5(uuid.NAMESPACE_DNS, sys.argv[1]))" "gent-$REPO_NAME")"
PROJ_DIR="$HOME/.claude/projects/$(printf '%s' "$REPO" | sed 's#/#-#g')"
RUN="$HOME/.gent-run.sh"
cat > "$RUN" <<EOF
#!/usr/bin/env bash
# Auto-generated by the gents bootstrap on every container start. Self-healing
# claude loop for this box. Stop it with \`gent down $REPO_NAME\`.
set -u
# Ignore SIGINT in this supervisor loop ITSELF. Ctrl+C at the claude prompt
# sends SIGINT to the whole pane process group — claude AND this bash. Without
# a trap, hitting Ctrl+C twice kills the loop too: the tmux window closes, the
# 'gent' session ends, the server exits, and the box goes brain-dead while the
# container still shows "up" (PID 1 below keeps it alive), so nothing respawns.
# A no-op handle (not SIG_IGN) keeps the loop alive; claude resets handlers on
# exec, so it still receives a normal Ctrl+C.
trap : INT
PINNED_ID="$PINNED_ID"
PROJ_DIR="$PROJ_DIR"
while :; do
  # Newest transcript = the box's current session: unchanged across a plain
  # restart, advanced to the fresh one after a gent-clear. None yet -> first boot,
  # so CREATE the box-owned seed id (--session-id; --resume of a nonexistent id
  # errors, --session-id of an existing one errors, hence the branch).
  newest="\$(ls -t "\$PROJ_DIR"/*.jsonl 2>/dev/null | head -1)"
  if [ -n "\$newest" ]; then set -- --resume "\$(basename "\$newest" .jsonl)"; else set -- --session-id "\$PINNED_ID"; fi
  claude --dangerously-skip-permissions -n "$REPO_NAME" "\$@"
  echo
  echo "[claude exited — relaunching in 5s; 'gent shell $REPO_NAME' for a shell, 'gent down $REPO_NAME' to stop]"
  sleep 5
done
EOF
chmod +x "$RUN"
tmux new-session -d -s gent -n claude -c "$REPO" "exec bash '$RUN'"

# Sidecar services declared in gent.json:services[] — long-running processes
# that run ALONGSIDE claude (e.g. a chat-bot poller). gents owns their
# lifecycle in dedicated, auto-restarting tmux windows; claude never spawns
# them, it just monitors their output (tail -F / Monitor).
if [ -f "$REPO/gent.json" ] && command -v jq >/dev/null 2>&1; then
  n=$(jq '.services | length' "$REPO/gent.json" 2>/dev/null || echo 0)
  i=0
  while [ "$i" -lt "${n:-0}" ]; do
    sname=$(jq -r ".services[$i].name" "$REPO/gent.json")
    scmd=$(jq -r ".services[$i].cmd" "$REPO/gent.json")
    echo "gents: starting service '$sname': $scmd" >&2
    tmux new-window -d -t gent -n "$sname" -c "$REPO" \
      "while :; do $scmd; echo \"[$sname exited — restarting in 3s]\"; sleep 3; done"
    i=$((i + 1))
  done
fi

echo "gents: claude live in tmux 'gent' (window 0); services in their own windows" >&2

# Greet on startup: once claude's TUI has settled, replay the box's hello (if any)
# so a freshly `up`ed box is oriented/kicked exactly like it is after a gent-clear.
# Backgrounded (child of PID 1, dies with the container); fires ONCE per container
# start — a claude crash-relaunch inside $RUN does NOT re-greet, only a real box
# (re)start does. No-op for boxes without a .gent/hello.md.
if [ -s "$REPO/.gent/hello.md" ]; then
  ( trap : INT
    # The pane exists immediately (the supervisor loop runs bash), but claude
    # takes a few seconds to boot its TUI — and a resumed box can spend MINUTES
    # auto-compacting a large transcript first. Sending into that churn drops the
    # paste. So wait for claude to be genuinely IDLE: the pane unchanged for a few
    # seconds AND not showing "esc to interrupt" (which it shows only while busy).
    # Generous cap; if it never goes idle, SKIP rather than blast into a busy
    # session — a missed greeting is recoverable (`gent-hello`), a dropped one
    # mid-compaction just looks broken.
    prev=""; stable=0; ready=0
    for _ in $(seq 1 300); do
      tmux has-session -t gent 2>/dev/null || exit 0
      cur="$(tmux capture-pane -p -t gent:claude 2>/dev/null || true)"
      if [ -n "$cur" ] && [ "$cur" = "$prev" ] && ! printf '%s' "$cur" | grep -q "esc to interrupt"; then
        stable=$((stable + 1)); if [ "$stable" -ge 3 ]; then ready=1; break; fi
      else
        stable=0
      fi
      prev="$cur"; sleep 1
    done
    if [ "$ready" = 1 ]; then gent-hello
    else echo "gents: startup greeting skipped — claude never went idle within cap" >&2; fi
  ) &
fi

# Periodic context-refresh NUDGE. If the repo's gent.json sets clear.every (e.g.
# "6h"), poke the claude pane on that cadence with an invitation to wrap up and
# run `gent-clear`. This is the ONLY thing on a timer — it never clears anything
# itself. The MODEL decides whether/when it's actually ready (work checkpointed,
# durable state saved) and runs `gent-clear`, which does the /clear + replays
# .gent/hello.md. Opt-in: no clear.every → no nudge loop. Backgrounded as a child
# of PID 1, so it dies with the container; it also self-exits if the session goes.
#
# IDLE-SKIP: we only nudge when something has actually happened since our last
# baseline. Without this, an idle box churns forever — it clears, the fresh
# session holds only the hello, the next nudge fires into it, and since "idle" IS
# a good stopping point the model clears AGAIN: an empty clear + re-greet every
# cadence on a quiet box. The newest transcript's path+size is the activity
# fingerprint (a /clear starts a fresh <id>.jsonl; turns append; a fully idle
# interval — including a pristine post-clear session — leaves it identical), so an
# unchanged fingerprint means "nothing happened, including the last clear" → skip.
CLEAR_EVERY_RAW=""
if [ -f "$REPO/gent.json" ] && command -v jq >/dev/null 2>&1; then
  CLEAR_EVERY_RAW="$(jq -r '.clear.every // empty' "$REPO/gent.json" 2>/dev/null || true)"
fi
if [ -n "$CLEAR_EVERY_RAW" ] && printf '%s' "${CLEAR_EVERY_RAW%[smhd]}" | grep -qE '^[0-9]+$'; then
  _n="${CLEAR_EVERY_RAW%[smhd]}"; _u="${CLEAR_EVERY_RAW#"$_n"}"
  case "$_u" in
    s|"") CLEAR_EVERY_SEC="$_n" ;;
    m)    CLEAR_EVERY_SEC=$((_n * 60)) ;;
    h)    CLEAR_EVERY_SEC=$((_n * 3600)) ;;
    d)    CLEAR_EVERY_SEC=$((_n * 86400)) ;;
    *)    CLEAR_EVERY_SEC=0 ;;
  esac
  if [ "${CLEAR_EVERY_SEC:-0}" -gt 0 ]; then
    NUDGE_TEXT="⏰ Context-refresh nudge: if you're at a good stopping point, wrap up — commit anything worth keeping, save durable notes to memory — then run \`gent-clear\` as your final action to reset your context. Mid-task? Ignore this; you'll be nudged again later."
    echo "gents: periodic clear nudge every ${CLEAR_EVERY_RAW} (${CLEAR_EVERY_SEC}s)" >&2
    ( trap : INT
      fp() { local n; n="$(ls -t "$PROJ_DIR"/*.jsonl 2>/dev/null | head -1 || true)"; [ -n "$n" ] && printf '%s:%s' "$n" "$(wc -c < "$n" 2>/dev/null || echo 0)"; }
      base="$(fp)"
      while :; do
        sleep "$CLEAR_EVERY_SEC"
        tmux has-session -t gent 2>/dev/null || exit 0
        [ "$(fp)" = "$base" ] && continue   # nothing happened since last baseline (incl. an idle post-clear session) — skip
        tmux send-keys -t gent:claude "$NUDGE_TEXT" Enter 2>/dev/null || true
        # Re-baseline AFTER the nudge is fully handled — wait for the session to go
        # quiescent (incl. any gent-clear: new transcript + re-greet), capped — so
        # the nudge's OWN churn isn't misread as fresh activity on the next tick.
        prev=""; stable=0
        for _ in $(seq 1 300); do
          tmux has-session -t gent 2>/dev/null || exit 0
          cur="$(fp)"
          if [ -n "$cur" ] && [ "$cur" = "$prev" ]; then
            stable=$((stable + 1)); [ "$stable" -ge 15 ] && break
          else stable=0; fi
          prev="$cur"; sleep 1
        done
        base="$cur"
      done ) &
  fi
fi

# Telegram inbound-Monitor watchdog. A tg box (gent.json declares a `tg poll`
# service) surfaces inbound by arming a persistent harness Monitor on `tg watch`,
# which pipes new messages into the live claude session. The harness can drop
# that Monitor with NO signal (context compaction, event-rate kill); when it does
# the child `tg watch` process dies with the task (verified by teardown test), so
# inbound silently stops surfacing while the agent still believes it's listening —
# the exact bug that bit lastro. A container restart kills it outright too. (It
# does NOT die on /clear — the Monitor survives the clear and keeps feeding the
# fresh session; verified by surfacing a sentinel post-clear. So gent-clear leaves
# it alone.) Only the MODEL can arm a harness Monitor, so the box can't re-arm
# directly: it pokes the pane and lets the model do it. The durable spine is the
# box-supervised `tg poll` → var/telegram/history.jsonl (independent of any
# session), so a gap is only ever a DELAY — on each re-arm the model reconciles
# history (latest in vs out per chat) and handles whatever landed meanwhile. This
# ONE loop covers both silent-drop death modes AND the initial arm at a fresh
# container start: the Monitor isn't up → it reads as "down" → we poke → model
# arms+reconciles. Self-gating means the single loop is harmless on non-tg boxes;
# opt-in via the service. Liveness is a plain process check — reliable because
# task teardown always kills the child (if a drop ever orphaned a live process,
# the worst case is a missed poke, recovered by reconcile at the next genuine arm).
TG_BOX=0
if [ -f "$REPO/gent.json" ] && command -v jq >/dev/null 2>&1; then
  jq -e '[.services[]?.cmd] | any(startswith("tg poll"))' "$REPO/gent.json" >/dev/null 2>&1 && TG_BOX=1
fi
if [ "$TG_BOX" = 1 ]; then
  REARM_TEXT="⚠️ Telegram inbound Monitor is DOWN — the persistent \`tg watch\` task isn't running, so new messages aren't surfacing here. Re-arm it now: start a persistent Monitor on \`tg watch\`. Then reconcile the gap: run \`tg pending\` and handle every chat/thread it lists (it shows inbound newer than your last reply). The poller never stopped, so nothing is lost — just catch up."
  echo "gents: telegram monitor watchdog armed (tg box)" >&2
  ( trap : INT
    sleep 30   # let a fresh session settle (hello, etc.) before the first check
    while :; do
      tmux has-session -t gent 2>/dev/null || exit 0
      # Liveness: inbound is surfaced by a persistent Monitor that either runs
      # `tg watch` OR tails history.jsonl directly — both are valid and different
      # boxes do it differently (e.g. axt tails), so match EITHER, else the
      # watchdog false-pokes a box whose monitor is a tail. A bare `pgrep` excludes
      # its own PID — but NEVER wrap this in a shell whose argv contains the pattern
      # (e.g. `bash -lc "pgrep -f …"`) or it matches that wrapper.
      if pgrep -f 'tg watch|history\.jsonl' >/dev/null 2>&1; then sleep 60; continue; fi
      # Monitor down — poke the model to re-arm + reconcile. Deliver it like
      # gent-hello: a bare `send-keys "$text" Enter` into a BUSY pane leaves the
      # text unsent in the composer (the Enter is swallowed mid-turn). So wait for
      # the pane to go idle (stable + not showing "esc to interrupt"), then
      # bracketed-paste the text and submit with a separate Enter — the same
      # primitive that makes the hello reliably land.
      prev=""; stable=0; ready=0
      for _ in $(seq 1 120); do
        tmux has-session -t gent 2>/dev/null || exit 0
        cur="$(tmux capture-pane -p -t gent:claude 2>/dev/null || true)"
        if [ -n "$cur" ] && [ "$cur" = "$prev" ] && ! printf '%s' "$cur" | grep -q 'esc to interrupt'; then
          stable=$((stable + 1)); [ "$stable" -ge 3 ] && { ready=1; break; }
        else stable=0; fi
        prev="$cur"; sleep 1
      done
      [ "$ready" = 1 ] || continue   # never went idle within ~2min — retry next cycle
      printf '%s' "$REARM_TEXT" | tmux load-buffer -b gent-tgrearm -
      tmux paste-buffer -b gent-tgrearm -t gent:claude -p -d
      tmux send-keys -t gent:claude Enter
      # DEBOUNCE: wait for `tg watch` to reappear (up to ~5min) before re-checking,
      # so we don't re-poke every tick while the model is acting on the first one.
      for _ in $(seq 1 60); do
        tmux has-session -t gent 2>/dev/null || exit 0
        pgrep -f 'tg watch|history\.jsonl' >/dev/null 2>&1 && break
        sleep 5
      done
      sleep 60
    done ) &
fi

# PID 1 fate-shares with the tmux session. If the whole session ever dies
# (kill-server, OOM, a signal that escapes the loop trap above), exit so
# Docker's `--restart unless-stopped` recreates the box and re-runs this
# bootstrap — instead of leaving a hollow container "up" forever (the old
# `tail -F /dev/null` never noticed, so the restart policy never fired).
while tmux has-session -t gent 2>/dev/null; do sleep 5; done
echo "gents: tmux 'gent' session gone — exiting so Docker restarts the box" >&2
