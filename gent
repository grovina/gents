#!/usr/bin/env python3
"""gent — keymaster CLI for the sandboxed agent fleet.

Reads fleet.json (machine-side grants, next to this script) and each target
repo's gent.json (repo-side requirements), and composes a `docker run` that
mounts only that repo + its granted secret slices, with this machine's
cpu/mem caps. One long-lived `claude --dangerously-skip-permissions` per repo,
in tmux, attachable from the host.

Stdlib only. The docker command is always printed before it runs — no magic.
"""
import argparse, json, os, re, shlex, shutil, subprocess, sys, time
from pathlib import Path

HERE = Path(__file__).resolve().parent
FLEET = HERE / "fleet.json"


def die(msg):
    print(f"gent: {msg}", file=sys.stderr)
    sys.exit(1)


def expand(p):
    return Path(os.path.expanduser(p)).resolve() if p else None


def load_fleet():
    if not FLEET.exists():
        die(f"no fleet.json at {FLEET} — copy fleet.example.json to fleet.json and add your repos")
    f = json.loads(FLEET.read_text())
    # state_root: the single relocatable home for all precious, non-git fleet
    # state — the secrets catalog + per-box app-state. rsync this one dir (plus the
    # repos and ~/.claude/projects) and the fleet's identity moves with it.
    # secrets_root defaults UNDER state_root; an explicit secrets_root still wins.
    f["state_root"] = expand(f.get("state_root", "~/.gent/state"))
    sr = f.get("secrets_root")
    f["secrets_root"] = expand(sr) if sr else f["state_root"] / "secrets"
    f["projects_root"] = expand(f.get("projects_root", "~/Projects"))
    return f


def repo_cfg(fleet, name):
    repos = fleet.get("repos", {})
    if name not in repos:
        die(f"'{name}' not in fleet.json (known: {', '.join(repos) or 'none'})")
    cfg = repos[name]
    if not cfg.get("allow"):
        die(f"'{name}' is not approved (set \"allow\": true in fleet.json — the trust gate)")
    cfg["abs_path"] = fleet["projects_root"] / cfg["path"]
    if not cfg["abs_path"].is_dir():
        die(f"repo path does not exist: {cfg['abs_path']}")
    return cfg


def read_gent_json(cfg):
    gj = cfg["abs_path"] / "gent.json"
    if gj.exists():
        try:
            return json.loads(gj.read_text())
        except json.JSONDecodeError as e:
            die(f"bad gent.json in {cfg['abs_path']}: {e}")
    return None


def container(name):
    return f"gent-{name}"


def docker(*args, capture=False, check=True):
    if capture:
        return subprocess.run(["docker", *args], capture_output=True, text=True).stdout.strip()
    return subprocess.run(["docker", *args], check=check)


def container_state(name):
    out = docker("ps", "-a", "--filter", f"name=^{container(name)}$",
                 "--format", "{{.State}}", capture=True)
    return out or "—"


# ── github deploy keys ───────────────────────────────────────────────────────

def github_slug(abs_path):
    """'owner/repo' for the repo's origin remote if it's on github, else None."""
    url = subprocess.run(["git", "-C", str(abs_path), "remote", "get-url", "origin"],
                         capture_output=True, text=True).stdout.strip()
    m = re.search(r"github\.com[:/]([^/]+/[^/]+?)(?:\.git)?$", url)
    return m.group(1) if m else None


def _gh(*args):
    """Run gh, returning the CompletedProcess, or None if gh isn't installed."""
    try:
        return subprocess.run(["gh", *args], capture_output=True, text=True)
    except FileNotFoundError:
        return None


def ensure_deploy_key(fleet, name, cfg):
    """Idempotent: a per-repo GitHub deploy key in the catalog, registered with
    WRITE access on this repo only. Returns the private-key path to mount, or
    None if the repo has no github remote. Never fatal — a box must still come
    up even if registration fails (e.g. you lack admin on the repo).

    The catalog holds one key per repo (ssh/<repo>-deploy); inside the box it's
    mounted at a fixed, repo-agnostic path. Blast radius = this one repo, the
    same scoping as the per-repo GCP SAs."""
    slug = github_slug(cfg["abs_path"])
    if not slug:
        return None
    keydir = fleet["secrets_root"] / "ssh"
    keydir.mkdir(parents=True, exist_ok=True)
    key = keydir / f"{name}-deploy"
    title = f"gent-{name}"

    created = False
    if not key.exists():
        print(f"gent: minting deploy key for {slug}  ({key})")
        subprocess.run(["ssh-keygen", "-t", "ed25519", "-N", "", "-q",
                        "-C", title, "-f", str(key)], check=True)
        key.chmod(0o600)
        created = True

    listed = _gh("repo", "deploy-key", "list", "-R", slug)
    if listed is None:
        print("gent: WARNING — gh not found; can't auto-register the deploy key. "
              f"Add {key}.pub to {slug} (write) by hand, or install gh.", file=sys.stderr)
        return key
    ids = [ln.split()[0] for ln in listed.stdout.splitlines()
           if len(ln.split()) >= 2 and ln.split()[1] == title]
    if created and ids:                    # stale key under our title — drop, re-add
        for kid in ids:
            _gh("repo", "deploy-key", "delete", kid, "-R", slug)
        ids = []
    if not ids:
        added = _gh("repo", "deploy-key", "add", f"{key}.pub", "-R", slug, "-w", "-t", title)
        if added.returncode != 0:
            print(f"gent: WARNING — couldn't register deploy key on {slug} "
                  f"(need admin on the repo?): {added.stderr.strip()}", file=sys.stderr)
        else:
            print(f"gent: deploy key registered (write) on {slug}")
    return key


# ── commands ─────────────────────────────────────────────────────────────────

def cmd_doctor(fleet, _a):
    ok = True
    if subprocess.run(["which", "docker"], capture_output=True).returncode:
        print("✗ docker not found on PATH"); ok = False
    else:
        running = subprocess.run(["docker", "info"], capture_output=True).returncode == 0
        print(f"{'✓' if running else '✗'} docker daemon {'up' if running else 'NOT running (start Docker Desktop)'}")
        ok = ok and running
        # VM memory: boxes share ONE Docker Desktop VM. A small VM (the default can
        # be ~4G) OOM-kills heavy work — a node `pnpm install` peaks past it — even
        # though the per-box --memory caps look generous (they overcommit the VM).
        # Soft floor; raise via Docker Desktop → Settings → Resources → Memory.
        if running:
            mt = docker("info", "--format", "{{.MemTotal}}", capture=True)
            gib = int(mt) / 1073741824 if mt.isdigit() else 0
            floor = 8
            print(f"{'✓' if gib >= floor else '!'} docker VM memory {gib:.1f} GiB"
                  + ('' if gib >= floor else f" — low (< {floor}); a heavy `pnpm install` can OOM. "
                     "Raise it in Docker Desktop → Settings → Resources."))
    img = fleet["image"]
    have = docker("images", "-q", img, capture=True)
    print(f"{'✓' if have else '✗'} base image {img} {'present' if have else 'missing — run: gent fleet build'}")
    sr = fleet["secrets_root"]
    print(f"{'✓' if sr.is_dir() else '·'} secrets_root {sr} {'' if sr.is_dir() else '(absent — fine until a repo needs a slice)'}")
    sc = fleet["secrets_root"] / "claude-home" / ".credentials.json"
    print(f"{'✓' if sc.exists() else '✗'} shared box login {'present (all boxes share it)' if sc.exists() else 'absent — `gent attach <repo>` and run /login once'}")
    # NB: per-repo catalog slices (github/<owner>.env, vercel/<team>.env, SA keys,
    # …) aren't pre-flighted here — they're owner/team-specific, and `gent up`
    # already fails fast on a box whose fleet entry lists a missing catalog entry.
    sys.exit(0 if ok else 1)


def cmd_ls(fleet, _a):
    print(f"{'REPO':<16}{'STATE':<12}{'CPU/MEM':<12}PATH")
    for name, cfg in fleet.get("repos", {}).items():
        res = cfg.get("resources", {})
        cm = f"{res.get('cpus','-')}/{res.get('memory','-')}"
        gate = "" if cfg.get("allow") else " (not approved)"
        print(f"{name:<16}{container_state(name):<12}{cm:<12}{cfg.get('path','?')}{gate}")


def cmd_fleet_up(fleet, _a):
    """Bring up every approved box that isn't already running. Batch-friendly:
    skips `allow: false` repos and already-running boxes, and never aborts the
    whole run on one repo's failure (missing image/path) — it reports per repo
    and moves on. Note `--restart unless-stopped` already revives boxes when the
    Docker daemon starts, so this is mainly for a fresh checkout or after a
    `gent fleet down`."""
    did = False
    for name, cfg in fleet.get("repos", {}).items():
        if not cfg.get("allow"):
            print(f"·  {name:<16} skipped (not approved)"); continue
        state = container_state(name)
        if state == "running":
            print(f"=  {name:<16} already running"); continue
        if state != "—":              # exited / created / paused — don't clobber
            print(f"!  {name:<16} exists (state: {state}) — `gent down {name}` to recreate"); continue
        print(f"↑  {name:<16} starting…")
        did = True
        try:
            cmd_up(fleet, argparse.Namespace(repo=name))
        except SystemExit:            # cmd_up died on this repo; keep going
            print(f"✗  {name:<16} failed (see message above)", file=sys.stderr)
    if not did:
        print("gent: nothing to bring up.")


def cmd_fleet_down(fleet, _a):
    """Stop + remove every box. Home volumes are always KEPT here — wiping every
    box's installs/state in one command is too sharp to put behind a fleet flag;
    wipe deliberately, per box, with `gent down <repo> --wipe`."""
    did = False
    for name in fleet.get("repos", {}):
        if container_state(name) == "—":
            continue
        print(f"↓  {name:<16} down")
        docker("rm", "-f", container(name), check=False)
        did = True
    print("gent: home volumes kept (per box: `gent down <repo> --wipe`)."
          if did else "gent: no boxes to bring down.")


def cmd_build(fleet, _a):
    ctx = HERE / "images" / "base"
    print(f"gent: building {fleet['image']} from {ctx}")
    docker("build", "-t", fleet["image"], str(ctx))


def cmd_up(fleet, a):
    cfg = repo_cfg(fleet, a.repo)
    gj = read_gent_json(cfg)
    name = a.repo
    cname = container(name)

    if container_state(name) not in ("—",):
        die(f"{cname} already exists (state: {container_state(name)}). `gent down {name}` first.")
    if not docker("images", "-q", fleet["image"], capture=True):
        die(f"base image {fleet['image']} missing — run: gent fleet build")

    # Per-repo named volume for /home/gent: the agent's installs, caches, shell
    # history and in-box claude state survive reboot, `down`, and rebuilds.
    # (System `apt` installs live in / — for those, use the repo's .gent/setup.sh
    # so the box stays reproducible.) Wipe with `gent down <repo> --wipe`.
    # Mount the repo at its REAL host absolute path (not a fixed /repo), and cd
    # there. This makes the box a path-faithful subset of your machine: claude's
    # per-project key (the cwd, slashes→dashes) is IDENTICAL host-side and in the
    # box, so the two share one per-repo namespace (see the project-dir bind
    # below). It also means each repo encodes DISTINCTLY — the old fixed /repo
    # collapsed every box into one `-repo` namespace, scrambling memory fleetwide.
    repo_dir = str(cfg["abs_path"])
    args = ["run", "-d", "--name", cname, "--hostname", cname,
            "--restart", "unless-stopped",
            "-v", f"{repo_dir}:{repo_dir}",
            "-v", f"gent-{name}-home:/home/gent",
            "-w", repo_dir,
            "-e", f"GENT_REPO_DIR={repo_dir}",
            # Suppress claude.ai account MCP connectors (Gmail/Calendar/Drive/…) in
            # every box BY DEFAULT. The fleet shares ONE login, so those connectors
            # ride the account into all boxes; this env var makes claude drop the
            # whole set at session start (it short-circuits before fetching them —
            # values 0/false/no/off all trigger it). Account-level, so there's no
            # per-box grant for it — the env var IS the boundary. Host sessions are
            # a separate process and keep their connectors. Re-up-safe (set on every
            # `up`), unlike the per-connector `/mcp` → Disable toggle. A box that
            # SHOULD have the connectors opts back in via fleet.json `env`
            # (`"ENABLE_CLAUDEAI_MCP_SERVERS": "1"`) — applied below, after this, so
            # the later -e wins (e.g. a box that uses them for home automation).
            "-e", "ENABLE_CLAUDEAI_MCP_SERVERS=0"]

    res = cfg.get("resources", {})
    if res.get("cpus"):   args += ["--cpus", str(res["cpus"])]
    if res.get("memory"): args += ["--memory", str(res["memory"])]

    # Auth: ALL boxes share ONE claude config dir (creds, settings, sessions) —
    # exactly like your host's many sessions share ~/.claude. One `/login` in any
    # box populates it; refreshes propagate to all (shared dir = rename-safe);
    # no per-box login, no daemon. Independent of the host's own Keychain login.
    shared_claude = fleet["secrets_root"] / "claude-home"
    shared_claude.mkdir(parents=True, exist_ok=True)
    args += ["-v", f"{shared_claude}:/home/gent/.claude"]

    # Per-repo Claude project state (memory + transcripts) lives in the HOST's
    # ~/.claude, keyed by the repo's absolute path — the SAME key the box uses now
    # that it works from that real path (above). Bind that one dir in, MASKING the
    # shared claude-home's projects/<key>, so your host sessions and this box read
    # and write ONE shared per-repo memory + transcript history. claude-home still
    # supplies the fleet login/creds/settings; only this repo's project subtree is
    # host-backed. (mkdir so a never-run-on-host repo still gets a clean dir.)
    encoded = repo_dir.replace("/", "-")
    host_proj = Path.home() / ".claude" / "projects" / encoded
    host_proj.mkdir(parents=True, exist_ok=True)
    args += ["-v", f"{host_proj}:/home/gent/.claude/projects/{encoded}"]

    # Shared fleet caches (npm/pip/uv) so boxes reuse one warm cache instead of
    # each re-downloading. Safe (content-addressable); a dedicated dir, not host's.
    cache = fleet["secrets_root"] / "cache"
    cache.mkdir(parents=True, exist_ok=True)
    args += ["-v", f"{cache}:/cache"]

    # Fleet-shared pnpm store (content-addressable package files, no secrets):
    # every package version is downloaded ONCE across the whole fleet and reused.
    # A NAMED volume (ext4 in the VM, fast + stable) — deliberately NOT the
    # bind-mounted /cache above, whose foreign (macOS) filesystem is exactly what
    # made pnpm strand a 600M store inside /repo. The store and each box's
    # node_modules are separate mounts, so pnpm copies from here into node_modules
    # (a hardlink would cross a mount boundary → EXDEV); the win is no re-downloads
    # fleet-wide, not on-disk dedup. npm_config_store_dir=/pnpm-store is set in the
    # image. Sibling to /cache; harmless for non-node boxes (an unused empty dir).
    args += ["-v", "gent-pnpm-store:/pnpm-store"]

    # Derived build outputs (node_modules, .venv, target, …) declared per repo in
    # gent.json:derived as {path: build-command}. Each is platform-specific, so it
    # must NOT be shared with the host over the repo bind mount — instead each box
    # builds its OWN on a private named volume mounted at <repo_dir>/<path>, which
    # MASKS the host's copy (your host checkout keeps working, untouched). bootstrap
    # chowns the fresh volume and runs the build before claude/services start.
    # Wiped with the home volume by `gent down <repo> --wipe`. Repos that declare
    # no `derived` are unaffected. This is the general primitive; the per-repo
    # build command (e.g. `pnpm install`) owns all tool-specific detail.
    for path in ((gj or {}).get("derived") or {}):
        slug = path.strip("/").replace("/", "-")
        args += ["-v", f"gent-{name}-{slug}:{repo_dir}/{path}"]
    # Curated git identity so in-box commits are attributed to you, not `gent`.
    gitcfg = fleet["secrets_root"] / "gitconfig"
    if gitcfg.exists():
        args += ["-v", f"{gitcfg}:/home/gent/.gitconfig:ro"]

    # NB: in-box `gh` (read a PR's title/diff/threads/CI via the GitHub API) is
    # auth'd by a GH_TOKEN that rides the catalog `env_files` below like any
    # other fragment — NOT special-cased here. It's granted PER REPO (e.g.
    # github/<owner>.env), scoped to the owner whose repos that box touches, and
    # kept READ-ONLY on purpose: a write scope would be a second push path that
    # defeats the per-repo deploy key, which must stay the ONLY way to write.
    # A box owned by a different org lists no github token (or its own).

    # Per-repo GitHub deploy key (write-scoped to THIS repo), minted + registered
    # idempotently, mounted read-only at a fixed, repo-agnostic path. Bootstrap
    # installs it as ~/.ssh/id_ed25519 so in-box `git push` just works. Inside
    # the box it's simply "the key"; the catalog holds one per repo.
    dkey = ensure_deploy_key(fleet, name, cfg)
    if dkey:
        args += ["-v", f"{dkey}:/secrets/ssh/key:ro"]

    # Catalog mounts: container_path -> reusable entry under secrets_root, ro.
    # The catalog is shared (one SA key can serve every repo in a project);
    # isolation is here, in the grant — a box sees only what this lists.
    for dest, rel in (cfg.get("mounts") or {}).items():
        src = fleet["secrets_root"] / rel
        if not src.exists():
            die(f"{name}: catalog entry missing: {src}  (-> {dest})")
        args += ["-v", f"{src}:{dest}:ro"]

    # Per-box precious app state, pulled OUT of the home volume / repo into the
    # relocatable state_root (~/.gent/state/app/<box>/<rel>) so a fleet move is a
    # plain dir copy — no `docker volume` export. Mounted read-WRITE (the app owns
    # it); when dest is under /home/gent it nests over the home volume, masking that
    # subtree so the state lands on the host bind, not the volume. (e.g.
    # filmograma's ~/.local/state/filmograma telegram state.)
    for dest, rel in (cfg.get("state_mounts") or {}).items():
        src = fleet["state_root"] / "app" / name / rel
        src.mkdir(parents=True, exist_ok=True)
        args += ["-v", f"{src}:{dest}"]

    # Reusable .env fragments from the catalog, then inline env.
    for rel in (cfg.get("env_files") or []):
        src = fleet["secrets_root"] / rel
        if not src.exists():
            die(f"{name}: catalog env_file missing: {src}")
        args += ["--env-file", str(src)]

    for k, v in (cfg.get("env") or {}).items():
        args += ["-e", f"{k}={v}"]

    args.append(fleet["image"])

    print("gent: docker " + " ".join(shlex.quote(x) for x in args))
    docker(*args)
    print(f"gent: {name} up. attach: gent attach {name}")
    if gj and gj.get("needs", {}).get("egress"):
        print(f"gent: note — {name} declares egress {gj['needs']['egress']}; "
              "enforcement is deferred (open egress for now).")


def _wait_session(name, timeout=90):
    """The container starts detached; bootstrap creates the tmux 'gent' session
    only after seeding config and running the repo's .gent/setup.sh — which can
    take a few seconds (longer on a fresh box). Poll so `gent attach` right
    after `up` doesn't race ahead and hit tmux 'no current target'."""
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        if subprocess.run(["docker", "exec", container(name), "tmux", "has-session", "-t", "gent"],
                          capture_output=True).returncode == 0:
            return True
        time.sleep(0.5)
    return False


def _attach(name):
    # Bootstrap may still be coming up (esp. immediately after `up`/onboard) —
    # wait for the session so we don't race into tmux 'no current target'.
    if not _wait_session(name):
        die(f"{container(name)} is running but its claude session hasn't appeared yet "
            f"(slow .gent/setup.sh?). Retry `gent attach {name}` shortly, or see `gent logs {name}`.")
    # Always land on the window named 'claude', never a service window (by name,
    # not index — order is unreliable once service windows exist).
    os.execvp("docker", ["docker", "exec", "-it", container(name),
                         "tmux", "select-window", "-t", "gent:claude", ";", "attach", "-t", "gent"])


def cmd_attach(fleet, a):
    repo_cfg(fleet, a.repo)
    _attach(a.repo)


def here_match(fleet):
    """Repo name whose configured path contains cwd, or None."""
    cwd = Path.cwd().resolve()
    for name, cfg in fleet.get("repos", {}).items():
        rp = (fleet["projects_root"] / cfg["path"]).resolve()
        if cwd == rp or rp in cwd.parents:
            return name
    return None


def cmd_shell(fleet, a):
    """A fresh terminal inside the box (separate from the claude session).
    `gent shell myapp`             -> interactive bash
    `gent shell myapp -- npm test` -> run a one-off command and exit."""
    repo_cfg(fleet, a.repo)
    if a.cmd_args:
        os.execvp("docker", ["docker", "exec", "-it", container(a.repo), "bash", "-lc", " ".join(a.cmd_args)])
    os.execvp("docker", ["docker", "exec", "-it", container(a.repo), "bash", "-l"])


def cmd_peek(fleet, a):
    repo_cfg(fleet, a.repo)
    docker("exec", container(a.repo), "tmux", "capture-pane", "-p", "-t", "gent", check=False)


def cmd_logs(fleet, a):
    repo_cfg(fleet, a.repo)
    docker("logs", "-n", "100", container(a.repo), check=False)


def cmd_down(fleet, a):
    repo_cfg(fleet, a.repo)
    docker("rm", "-f", container(a.repo), check=False)
    if getattr(a, "wipe", False):
        docker("volume", "rm", f"gent-{a.repo}-home", check=False)
        print(f"gent: {a.repo} down + home volume wiped (clean slate)")
    else:
        print(f"gent: {a.repo} down (home volume kept; --wipe to clear installs/state)")


def cmd_auth(fleet, _a):
    """Boxes share ONE login (a shared ~/.claude). Attach any box and run
    `/login` once — it populates the shared dir and every box is then logged in."""
    shared_creds = fleet["secrets_root"] / "claude-home" / ".credentials.json"
    if shared_creds.exists():
        print(f"gent: boxes already share a login ({shared_creds}).")
    else:
        print("gent: boxes share ONE login. `gent attach <repo>` into any box, then `/login` once;")
        print("       it populates the shared ~/.claude and every box is logged in.")


def cmd_fleet_refresh_auth(fleet, _a):
    """Keep the shared box login fresh while the fleet idles (built for cron).

    Every box shares ONE 8-hour OAuth access token. An ACTIVE box re-mints it as
    a side effect of its own calls, so this is normally a no-op. But if the WHOLE
    fleet sits idle past expiry, nothing triggers a refresh: each box's Remote
    Control socket drops at expiry and doesn't recover until its session
    restarts. This is that restart, on a timer.

    A still-valid token is reused as-is (verified: restarting doesn't re-mint an
    unexpired token), so acting early would bounce sessions for nothing — we wait
    for actual expiry. Then we bounce ONE box first (its restart re-mints the
    token and writes the shared file), confirm the new expiry landed, and only
    THEN bounce the rest (which read the fresh token). Never all at once: the
    refresh token is single-use, so 9 boxes racing on it would strand 8."""
    creds = fleet["secrets_root"] / "claude-home" / ".credentials.json"
    if not creds.exists():
        print("gent: no shared login yet — `gent attach <repo>` then `/login` once.")
        return
    try:
        exp_ms = json.loads(creds.read_text())["claudeAiOauth"]["expiresAt"]
    except (json.JSONDecodeError, KeyError, OSError) as e:
        die(f"can't read token expiry from {creds}: {e}")
    GRACE = 60  # seconds; catch right-at-expiry ticks without acting early
    remaining = exp_ms / 1000 - time.time()
    if remaining > GRACE:
        print(f"gent: shared token valid for ~{int(remaining // 60)}m — nothing to do.")
        return
    running = [n for n in fleet.get("repos", {}) if container_state(n) == "running"]
    if not running:
        print("gent: token expired but no boxes running — nothing to refresh.")
        return
    leader, rest = running[0], running[1:]
    print(f"gent: shared token expired — re-minting via {leader}, then reconnecting "
          f"{len(rest)} more.")
    # Leader: kill claude; the box's self-healing supervisor relaunches it, and on
    # startup claude re-mints the expired token and writes the shared file. Poll
    # until expiresAt advances so we know the refresh landed before touching the rest.
    docker("exec", container(leader), "pkill", "-x", "claude", check=False)
    deadline, new_exp = time.time() + 90, exp_ms
    while time.time() < deadline:
        time.sleep(3)
        try:
            new_exp = json.loads(creds.read_text())["claudeAiOauth"]["expiresAt"]
        except (json.JSONDecodeError, KeyError, OSError):
            continue
        if new_exp > exp_ms:
            break
    if new_exp <= exp_ms:
        die(f"{leader} did not re-mint the token within 90s — the refresh token may be "
            f"revoked/expired. Re-login: `gent attach {leader}`, then `/login`. "
            f"Left the other boxes untouched.")
    print(f"gent: token re-minted (valid ~{int((new_exp / 1000 - time.time()) // 60)}m). "
          f"reconnecting: {', '.join(rest) or '(none)'}")
    for n in rest:
        docker("exec", container(n), "pkill", "-x", "claude", check=False)
    print(f"gent: done — {len(running)} session(s) bounced; Remote Control reconnects shortly.")


# ── the host's own claude session (`gent host …`) ────────────────────────────
# A box stays reachable while idle because its bootstrap supervisor relaunches a
# crashed claude AND, since an ACTIVE box re-mints its 8h OAuth token as a side
# effect of its own calls, Remote Control never lapses. A claude you run ON the
# host, by hand, has neither: nothing relaunches it, and once it sits idle past
# token expiry its Remote Control socket drops with no way back in (the phone
# can't poke it; the dropped socket only recovers on a session restart). These
# commands give the host session the same two safety nets the fleet already has —
# a self-healing tmux supervisor (`gent host up`) and a keepalive that pokes it
# to re-mint before expiry, or bounces it to reconnect after (`gent host
# keepalive`, the host-side sibling of `gent fleet refresh-auth`).

HOST_KEEPALIVE_POKE = "⏳ Remote-Control keepalive — token near expiry; no action needed, please ignore."

# Self-healing supervisor written to ~/.gent-<name>-run.sh and run inside tmux.
# @@-tokens are filled by str.replace (the body is full of shell ${} braces, so
# .format/f-strings are the wrong tool here).
HOST_SUPERVISOR = r'''#!/usr/bin/env bash
# Auto-generated by `gent host up` — the host-side analogue of a box's bootstrap
# supervisor, for THIS machine's own long-lived claude session "@@NAME@@".
#
# Two jobs, mirroring how a box stays reachable while idle:
#   1. SELF-HEAL: relaunch claude if it exits (crash/OOM), resuming the newest
#      transcript so Remote Control reconnects the SAME session, not a ghost.
#   2. KEEPALIVE child: every 15m, nudge `gent host keepalive`, which pokes an
#      idle session nearing token expiry so it re-mints in place (and bounces it
#      if the token already lapsed, e.g. after the laptop slept). This is what an
#      ACTIVE box gets for free from its own API calls.
# Stop everything: tmux kill-session -t @@NAME@@
set -u
trap : INT   # Ctrl+C reaches claude (it resets handlers on exec), not this loop.
PROJ_DIR="@@PROJ@@"

# Keepalive child — exits when the session is gone, so it dies with the session.
( trap : INT
  while :; do
    sleep 900
    tmux has-session -t @@NAME@@ 2>/dev/null || exit 0
    /usr/bin/python3 "@@GENT@@" host keepalive --quiet >/dev/null 2>&1 || true
  done ) &

while :; do
  # Newest transcript = this session across plain relaunches; resume it so the
  # phone keeps ONE Remote Control session. None yet (true first run) -> plain start.
  newest="$(ls -t "$PROJ_DIR"/*.jsonl 2>/dev/null | head -1)"
  if [ -n "$newest" ]; then set -- --resume "$(basename "$newest" .jsonl)"; else set --; fi
  claude -n "@@NAME@@" "$@"
  echo
  echo "[claude exited — relaunching in 5s; 'tmux attach -t @@NAME@@' to watch, 'tmux kill-session -t @@NAME@@' to stop]"
  sleep 5
done
'''

HOST_KEEPALIVE_PLIST = '''<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>@@LABEL@@</string>
    <!-- Invoke gent via system python3 explicitly (gent is stdlib-only) to avoid
         the pyenv shim, which needs PATH/init launchd won't have. -->
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>@@GENT@@</string>
        <string>host</string>
        <string>keepalive</string>
    </array>
    <!-- launchd starts with a bare PATH; keepalive shells out to `tmux`
         (homebrew), so pin it here. -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
    <!-- Every 10 min. A no-op while the host token is comfortably valid; pokes
         only inside the pre-expiry window, and survives laptop sleep (launchd
         fires on wake) so a post-sleep dropped socket gets bounced back. -->
    <key>StartInterval</key>
    <integer>600</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/@@LABEL@@.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/@@LABEL@@.log</string>
</dict>
</plist>
'''


def host_name(fleet):
    """Display + tmux session name for the host's own claude. Generic default;
    set "host": {"name": "…"} in fleet.json to personalise (kept out of the repo)."""
    return (fleet.get("host") or {}).get("name", "host")


def have_tmux():
    return shutil.which("tmux") is not None


def tmux_has(session):
    if not have_tmux():
        return False
    return subprocess.run(["tmux", "has-session", "-t", session],
                          capture_output=True).returncode == 0


def host_creds():
    """The HOST's own Claude login (distinct from the fleet's shared box login).
    On macOS it lives in the login Keychain, not a file — the bare
    ~/.claude/.credentials.json path is the Linux/box convention. Try the
    Keychain first, then fall back to the file for non-darwin hosts."""
    if sys.platform == "darwin":
        r = subprocess.run(["security", "find-generic-password",
                            "-s", "Claude Code-credentials", "-w"],
                           capture_output=True, text=True)
        if r.returncode == 0 and r.stdout.strip():
            try:
                return json.loads(r.stdout)
            except json.JSONDecodeError:
                pass
    f = Path.home() / ".claude" / ".credentials.json"
    if f.exists():
        try:
            return json.loads(f.read_text())
        except (json.JSONDecodeError, OSError):
            pass
    return None


def host_token_remaining():
    """Seconds until the host login expires, or None if unreadable."""
    c = host_creds()
    try:
        return c["claudeAiOauth"]["expiresAt"] / 1000 - time.time()
    except (KeyError, TypeError):
        return None


# Make `gent host attach` feel like `gent attach <box>`. The boxes load a
# system-wide /etc/tmux.conf (images/base/tmux.conf); the host session instead
# runs on the user's own tmux server, so it'd inherit their config (usually no
# `mouse on`) and the wheel falls through to claude as arrow keys. Apply the same
# behavioral options here, scoped to THIS session (set-option -t) so we never
# touch the user's other tmux sessions. Session-scoped options only.
HOST_TMUX_OPTS = (
    ("mouse", "on"),          # wheel scrolls claude's TUI, like the boxes
    ("status", "off"),        # tmux disappears — host claude IS the CLI
    ("focus-events", "on"),   # claude wants pane focus in/out
)

def apply_host_tmux_opts(name):
    """Idempotent; safe to call on every up/attach (incl. an already-running
    session, so the fix lands without a restart)."""
    if not tmux_has(name):
        return
    for opt, val in HOST_TMUX_OPTS:
        subprocess.run(["tmux", "set-option", "-t", name, opt, val],
                       check=False, capture_output=True)


def cmd_host_up(fleet, a):
    """Start (or report) this host's supervised claude session in tmux. Resumes
    the newest transcript in the launch dir, so the phone reconnects the SAME
    Remote Control session it had before."""
    name = host_name(fleet)
    if not have_tmux():
        die("host sessions need tmux (the poke channel that keeps idle Remote Control alive). "
            "Install it: `brew install tmux`, then re-run.")
    if tmux_has(name):
        print(f"gent: host session '{name}' already running — `gent host attach` to join.")
    else:
        cwd = expand(a.cwd) if getattr(a, "cwd", None) else Path.cwd()
        if not cwd.is_dir():
            die(f"--cwd does not exist: {cwd}")
        # claude keys per-project state by the working dir, slashes -> dashes.
        proj_dir = Path.home() / ".claude" / "projects" / str(cwd).replace("/", "-")
        run = Path.home() / f".gent-{name}-run.sh"
        run.write_text(HOST_SUPERVISOR
                       .replace("@@NAME@@", name)
                       .replace("@@PROJ@@", str(proj_dir))
                       .replace("@@GENT@@", str(HERE / "gent")))
        run.chmod(0o755)
        subprocess.run(["tmux", "new-session", "-d", "-s", name, "-n", "claude",
                        "-c", str(cwd), f"exec bash {shlex.quote(str(run))}"], check=True)
        apply_host_tmux_opts(name)
        print(f"gent: host session '{name}' up in tmux (cwd {cwd}).")
    # Arm the launchd keepalive every time (idempotent), so a single `up` is all it
    # takes — no separate install step, and a re-run re-arms it after a gent update.
    # launchd survives laptop sleep (fires on wake) to bounce a dropped socket the
    # in-tmux child's frozen sleep clock would miss.
    if install_host_keepalive(fleet, load=True, quiet=True):
        print(f"      keepalive armed (launchd, every 10m — survives sleep).")
    print(f"      attach: gent host attach   |   stop: tmux kill-session -t {name}")


def cmd_host_attach(fleet, a):
    name = host_name(fleet)
    if not tmux_has(name):
        die(f"host session '{name}' not running — `gent host up` first.")
    apply_host_tmux_opts(name)  # also fixes an already-running session in place
    subprocess.run(["tmux", "attach", "-t", name])


def cmd_host_down(fleet, a):
    """Stop the host session: kill its tmux session and remove the run script.
    Also reaps any orphaned `claude -n <name>` that outlived the tmux pane (a
    detached Remote Control session claude can keep alive on its own, which
    nothing would relaunch). Leaves the launchd keepalive — it's a no-op while
    the session is down and `up` re-arms it; pass --keepalive to remove it too."""
    name = host_name(fleet)
    if tmux_has(name):
        subprocess.run(["tmux", "kill-session", "-t", name])
        print(f"gent: host session '{name}' stopped.")
    else:
        print(f"gent: host session '{name}' not running.")
    # Match the EXACT name argument (space or end-of-line after it) so a different
    # session's claude — e.g. your own `claude -n gents` shell — is never touched.
    orphans = [p for p in subprocess.run(
        ["pgrep", "-f", f"claude -n {name}( |$)"],
        capture_output=True, text=True).stdout.split() if p.isdigit()]
    if orphans:
        subprocess.run(["kill", *orphans], capture_output=True)
        print(f"gent: reaped {len(orphans)} orphaned '{name}' claude process(es).")
    run = Path.home() / f".gent-{name}-run.sh"
    if run.exists():
        run.unlink()
    if getattr(a, "keepalive", False) and sys.platform == "darwin":
        label = f"gent-host-keepalive-{name}"
        plist = Path.home() / "Library" / "LaunchAgents" / f"{label}.plist"
        subprocess.run(["launchctl", "bootout", f"gui/{os.getuid()}/{label}"],
                       capture_output=True)
        plist.unlink(missing_ok=True)
        print(f"gent: keepalive job removed.")


def cmd_host_keepalive(fleet, a):
    """Keep an idle host session's Remote Control alive (built for cron/launchd).

    An active session re-mints its own token, so this is a no-op until the token
    nears expiry. In the pre-expiry window we POKE an idle session (a one-line,
    ignore-me prompt) to trigger an in-place re-mint — non-disruptive, and skipped
    entirely if the session is busy (it's re-minting itself) or if we'd be acting
    too early. Only once the token has actually lapsed — the post-sleep case where
    the socket already dropped and a poke can't revive it — do we BOUNCE claude,
    letting the supervisor relaunch it to re-mint and reconnect Remote Control."""
    name = host_name(fleet)
    quiet = getattr(a, "quiet", False)
    def say(m):
        if not quiet:
            print(f"gent: {m}")
    if not tmux_has(name):
        say(f"host session '{name}' not running — nothing to keep alive.")
        return
    remaining = host_token_remaining()
    if remaining is None:
        say("no readable host login (Keychain/credentials) — nothing to do.")
        return
    # Poke only in the last stretch before expiry — enough launchd/child ticks to
    # land a re-mint, but not so wide it wakes an idle session needlessly. The
    # expired-bounce below backstops any poke that didn't take.
    POKE_WINDOW = 30 * 60
    GRACE = 120             # at/under this, treat as expired -> bounce, don't poke
    if remaining > POKE_WINDOW:
        say(f"host token valid ~{int(remaining // 60)}m — nothing to do.")
        return
    target = f"{name}:claude"
    pane = subprocess.run(["tmux", "capture-pane", "-p", "-t", target],
                          capture_output=True, text=True).stdout
    if remaining > GRACE:
        if "esc to interrupt" in pane:   # busy => making calls => re-minting itself
            say(f"token ~{int(remaining // 60)}m out but session is active (re-mints itself) — skip.")
            return
        say(f"token ~{int(remaining // 60)}m from expiry — poking idle session to re-mint.")
        subprocess.run(["tmux", "send-keys", "-t", target, HOST_KEEPALIVE_POKE, "Enter"])
        return
    # Expired (or all but): socket has likely dropped. Bounce just THIS session's
    # claude (the supervisor pane's direct child) — never `pkill claude`, which
    # would also kill the user's other host sessions sharing this login.
    pid = subprocess.run(["tmux", "list-panes", "-t", target, "-F", "#{pane_pid}"],
                         capture_output=True, text=True).stdout.strip().splitlines()
    if pid:
        say("host token expired — bouncing claude so it re-mints + reconnects Remote Control.")
        subprocess.run(["pkill", "-P", pid[0], "-x", "claude"])
    else:
        say("host token expired but couldn't find the session's claude to bounce.")


def install_host_keepalive(fleet, load=True, quiet=False):
    """Write (and optionally load) the launchd job that runs `gent host keepalive`
    every 10 min — the host-side twin of the fleet's refresh-auth job. The plist
    is per-machine, so it's generated here, never committed. Idempotent; launchd
    is darwin-only, so this is a no-op (returns None) elsewhere — the supervisor's
    own in-tmux keepalive child still covers the awake-and-running case there."""
    if sys.platform != "darwin":
        return None
    name = host_name(fleet)
    label = f"gent-host-keepalive-{name}"
    plist = Path.home() / "Library" / "LaunchAgents" / f"{label}.plist"
    plist.parent.mkdir(parents=True, exist_ok=True)
    plist.write_text(HOST_KEEPALIVE_PLIST
                     .replace("@@LABEL@@", label)
                     .replace("@@GENT@@", str(HERE / "gent")))
    if not quiet:
        print(f"gent: wrote {plist}")
    if load:
        uid = os.getuid()
        subprocess.run(["launchctl", "bootout", f"gui/{uid}/{label}"],
                       capture_output=True)  # idempotent: clear any old copy
        subprocess.run(["launchctl", "bootstrap", f"gui/{uid}", str(plist)], check=False)
        if not quiet:
            print(f"gent: loaded — keepalive runs every 10m (logs: /tmp/{label}.log).")
    elif not quiet:
        print(f"      load it: launchctl bootstrap gui/$(id -u) {plist}")
    return plist


def cmd_host_install_keepalive(fleet, a):
    """Re-install or pre-arm the keepalive launchd job by hand. `gent host up`
    already does this automatically — this stays for re-installing after a gent
    update or arming ahead of an `up`, mirroring `deploy-key`."""
    install_host_keepalive(fleet, load=getattr(a, "load", False), quiet=False)


def cmd_host_status(fleet, a):
    name = host_name(fleet)
    up = tmux_has(name)
    remaining = host_token_remaining()
    tok = "no host login found" if remaining is None else (
        f"~{int(remaining // 60)}m left" if remaining > 0 else "EXPIRED")
    label = f"gent-host-keepalive-{name}"
    ka = (Path.home() / "Library" / "LaunchAgents" / f"{label}.plist").exists()
    print(f"gent: host session '{name}': {'up' if up else 'down'}  |  token: {tok}  |  "
          f"keepalive job: {'installed' if ka else 'not installed'}")


def cmd_deploy_key(fleet, a):
    """Mint + register this repo's write-scoped GitHub deploy key (idempotent).
    Runs automatically on `up`; exposed standalone to set it up ahead of time
    or after rotating."""
    cfg = repo_cfg(fleet, a.repo)
    key = ensure_deploy_key(fleet, a.repo, cfg)
    if not key:
        die(f"{a.repo}: origin is not a github remote — nothing to set up")
    print(f"gent: {a.repo} deploy key ready: {key}")


REPO_CMDS = ("up", "down", "attach", "shell", "peek", "logs", "deploy-key")


def main():
    fleet = load_fleet()
    # Nothing is implicit: bare `gent` prints usage and exits, like bare `git`.
    # Every effect is named — a box command, or the `fleet` admin group.
    p = argparse.ArgumentParser(prog="gent", description="sandboxed agent fleet (one box per repo)")
    sub = p.add_subparsers(dest="cmd", metavar="<command>")

    # `gent ls` — the daily glance; a top-level shortcut for `gent fleet ls`.
    sub.add_parser("ls", help="fleet overview (shortcut for `gent fleet ls`)")

    # `gent fleet …` — host/fleet admin you run rarely (setup, image, login).
    fp = sub.add_parser("fleet", help="fleet/host admin: ls, doctor, build, auth")
    fsub = fp.add_subparsers(dest="fleet_cmd", metavar="<command>")
    fsub.add_parser("ls",     help="list all boxes and their state")
    fsub.add_parser("up",     help="bring up every approved box not already running")
    fsub.add_parser("down",   help="stop + remove all boxes (home volumes kept)")
    fsub.add_parser("doctor", help="check host setup (docker, image, login)")
    fsub.add_parser("build",  help="build the base image")
    fsub.add_parser("auth",   help="shared-login status")
    fsub.add_parser("refresh-auth", help="re-mint the shared login if it expired while the fleet idled (for cron)")

    # `gent host …` — THIS machine's own claude session (run on the host, not in a
    # box): give it a box's idle-survival (supervisor + keepalive) for Remote Control.
    hp = sub.add_parser("host", help="this host's own supervised claude session (idle-proof Remote Control)")
    hsub = hp.add_subparsers(dest="host_cmd", metavar="<command>")
    hup = hsub.add_parser("up", help="start the supervised host session in tmux (resumes newest transcript)")
    hup.add_argument("--cwd", help="working dir for the session (default: current dir)")
    hdn = hsub.add_parser("down", help="stop the host session (kill tmux + remove run script)")
    hdn.add_argument("--keepalive", action="store_true", help="also remove the launchd keepalive job")
    hsub.add_parser("attach", help="attach to the host session")
    hsub.add_parser("status", help="show session state + token expiry + keepalive job")
    hk = hsub.add_parser("keepalive", help="poke/bounce the host session so idle Remote Control survives (for cron)")
    hk.add_argument("--quiet", action="store_true", help="stay silent on no-op ticks (for launchd)")
    hik = hsub.add_parser("install-keepalive", help="re-arm the keepalive launchd job (already automatic on `up`)")
    hik.add_argument("--load", action="store_true", help="also load it into launchd now")

    # Per-repo box commands — repo defaults to the cwd's repo when omitted.
    sub.add_parser("up",         help="create + start a repo's box").add_argument("repo", nargs="?")
    sub.add_parser("attach",     help="attach to a box's claude session").add_argument("repo", nargs="?")
    sub.add_parser("peek",       help="print a box's claude pane without attaching").add_argument("repo", nargs="?")
    sub.add_parser("logs",       help="show a box's recent container logs").add_argument("repo", nargs="?")
    sub.add_parser("deploy-key", help="mint + register this repo's GitHub deploy key").add_argument("repo", nargs="?")
    sp = sub.add_parser("down", help="stop + remove a box (home volume kept unless --wipe)")
    sp.add_argument("repo", nargs="?")
    sp.add_argument("--wipe", action="store_true", help="also delete the home volume")
    sp = sub.add_parser("shell", help="open a shell in a box (or run a one-off after --)")
    sp.add_argument("repo", nargs="?")
    sp.add_argument("cmd_args", nargs="*", help="optional one-off command after --")

    a = p.parse_args()
    if not a.cmd:                      # bare `gent` → usage, exits non-zero
        p.print_help(sys.stderr); sys.exit(1)
    if a.cmd == "fleet":
        if not a.fleet_cmd:            # bare `gent fleet` → group usage
            fp.print_help(sys.stderr); sys.exit(1)
        # Prefer a fleet-specific handler (cmd_fleet_up/down) so it doesn't
        # collide with the per-repo cmd_up/cmd_down; the rest (ls/doctor/build/
        # auth) fall through to the shared cmd_* (gent ls == gent fleet ls).
        key = a.fleet_cmd.replace('-', '_')
        fn = globals().get(f"cmd_fleet_{key}") or globals()[f"cmd_{key}"]
        return fn(fleet, a)
    if a.cmd == "host":
        if not a.host_cmd:             # bare `gent host` → group usage
            hp.print_help(sys.stderr); sys.exit(1)
        return globals()[f"cmd_host_{a.host_cmd.replace('-', '_')}"](fleet, a)
    if a.cmd in REPO_CMDS and not getattr(a, "repo", None):
        a.repo = here_match(fleet) or die("specify a repo, or run from inside a configured repo")
    globals()[f"cmd_{a.cmd.replace('-', '_')}"](fleet, a)


if __name__ == "__main__":
    main()
